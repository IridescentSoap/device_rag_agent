# 复制为 .env 后填写（勿提交 .env）
LLM_API_KEY=
# 兼容旧变量名（未设置 LLM_API_KEY 时回退）
DASHSCOPE_API_KEY=
OPENAI_API_KEY=
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
RAG_EMBEDDING_MODEL=./models/embedding/bge-large-zh-v1.5
RAG_LLM_MODEL=qwen-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 推理设备（有 GPU 时建议 Rerank 用 cuda，Embedding 可保持 cpu）
RAG_EMBEDDING_DEVICE=cpu
RAG_LOCAL_RERANK_DEVICE=cuda
# 本机 CUDA 上建议 float16（bf16 可能 illegal memory access）
RAG_QWEN3_RERANK_DTYPE=float16
RAG_QWEN3_RERANK_MAX_LENGTH=2048

# Agent 快速模式（缩小池子与 Rerank，显著降延迟）
# AGENT_FAST_MODE=1
# AGENT_FAST_PER_SOURCE_POOL=24
# AGENT_FAST_RERANK_TOPK=20
# AGENT_FAST_FINAL_TOPK=12
# AGENT_FAST_QWEN3_RERANK_MAX_LENGTH=1024
# AGENT_FAST_RERANK_BATCH_SIZE=4
# AGENT_FAST_RERANK_DOC_CHARS=1500

# Agent LLM Planner（复杂问题路由与子问题拆解；失败回退规则 Planner）
AGENT_LLM_PLANNER=0
AGENT_LLM_PLANNER_MODEL=qwen-plus
AGENT_LLM_PLANNER_TEMPERATURE=0

# Query Decomposition（复合问题拆解为原子子问题；默认规则，可选 LLM 增强）
# AGENT_LLM_DECOMPOSE=1
# AGENT_LLM_DECOMPOSE_MODEL=qwen-plus
# AGENT_LLM_DECOMPOSE_TEMPERATURE=0
# AGENT_DECOMPOSE_MAX_SUB_QUERIES=4

# 多轮追问 Query Rewrite（上下文消解；默认规则，可选 LLM 增强）
# AGENT_LLM_REWRITE=1
# AGENT_LLM_REWRITE_MODEL=qwen-plus
# AGENT_LLM_REWRITE_TEMPERATURE=0
# AGENT_LLM_REWRITE_HISTORY_TURNS=5
